encode_term(List, Depth) when is_list(List) ->
    [encode_term(X, Depth + 1) || X <- List];
encode_term(Map, Depth) when is_map(Map) ->
    maps:map(fun(_K, V) -> encode_term(V, Depth + 1) end, Map);
encode_term(Other, _Depth) -> Other.

