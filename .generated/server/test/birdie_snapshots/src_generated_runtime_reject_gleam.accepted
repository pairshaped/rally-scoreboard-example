//// Generated. Do not edit.
////
//// Cross-Mount command rejection helper.
//// Derived from the Generator Framework's Mount dispatch contract: a
//// ToServer constructor is only valid for the Mount that owns its handler.
//// Other-Mount constructors are rejected with an issue log entry.
////
//// This replaces silent no-ops with observable rejection so operators
//// can detect misrouted commands and incorrect client wiring.

import generated/runtime/effect.{type Effect}
import generated/runtime/system_db
import gleam/option.{type Option, None, Some}
import server/server_context.{type ServerContext}
import shared/api/to_client.{type ToClient}
import sqlight

pub fn reject_invalid_command(
  mount mount: String,
  command command: String,
  session_id session_id: String,
  user_id user_id: Option(Int),
  hostname hostname: String,
  server_context server_context: ServerContext,
  backend_model backend_model: model,
) -> #(model, Effect(ToClient)) {
  log_rejection(
    mount:,
    command:,
    session_id:,
    user_id:,
    hostname:,
    system_db: server_context.system_db,
  )
  #(backend_model, effect.none())
}

fn log_rejection(
  mount mount: String,
  command command: String,
  session_id session_id: String,
  user_id user_id: Option(Int),
  hostname hostname: String,
  system_db system_db: sqlight.Connection,
) -> Nil {
  system_db.log_issue(
    db: system_db,
    session_id: Ok(session_id),
    user_id: case user_id {
      Some(id) -> Ok(id)
      None -> Error(Nil)
    },
    user_email: Error(Nil),
    mount:,
    route: Ok(command),
    kind: "invalid_command",
    message: "Mount '"
      <> mount
      <> "' rejected ToServer '"
      <> command
      <> "' from host '"
      <> hostname
      <> "'",
    message_type: Ok(command),
    trace: Error(Nil),
    context: Error(Nil),
  )
}

